# Copy this file to .env and adjust values before deploying anywhere real.

APP_NAME=SentinelView
ENV=development
DEBUG=true

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- MySQL ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=sentinel
MYSQL_PASSWORD=sentinel_dev_password
MYSQL_DB=sentinelview

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- CORS (comma-separated in .env is NOT supported by pydantic list parsing by
# default; edit CORS_ORIGINS directly in app/core/config.py for multiple origins,
# or set as a JSON array string: ["http://localhost:5173"] )
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Ingestion ---
# Shared secret the log-shipper agent(s) and any external forwarder must send
# as ?api_key=... on POST /api/v1/events/push
INGEST_API_KEY=change-me-shared-secret

# --- Alerting integrations (all optional) ---
ALERT_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# --- Threat intel (optional, nice-to-have) ---
ABUSEIPDB_API_KEY=

# --- Correlation tuning ---
ALERT_DEDUP_WINDOW_SECONDS=300
BRUTE_FORCE_WINDOW_SECONDS=300
BRUTE_FORCE_THRESHOLD=5
PORT_SCAN_WINDOW_SECONDS=60
PORT_SCAN_DISTINCT_PORTS=10
